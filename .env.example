# Supabase — stesso progetto del CRM
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # NON la anon key — serve per bypassare RLS

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxx

# Secret per HMAC token approve/reject (genera con: openssl rand -hex 32)
APPROVE_SECRET=cambia_con_stringa_random_lunga

# Email di admin (dove arrivano le notifiche di nuove richieste)
ADMIN_EMAIL=nicola@timbro.agency

# URL base per i link nelle email (senza trailing slash)
NEXT_PUBLIC_BASE_URL=https://timbros.it

# URL del CRM dove verranno reindirizzati gli utenti approvati
NEXT_PUBLIC_CRM_URL=https://crm.timbros.it
